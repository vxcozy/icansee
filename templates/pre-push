#!/usr/bin/env bash
# icansee: pre-push rendered-DOM accessibility gate.
#
# Builds the project, serves it, runs @axe-core/cli against the routes in
# .icansee/routes.json. Same engine as the CI workflow and Vercel's
# Accessibility Audit Tool. Blocks the push on any finding.
#
# Bypass with `git push --no-verify` (CI will still catch it).
#
# Skips when no app code is being pushed (commits-only changes to
# README, .github docs, etc.). See filter logic below.

set -e

ICANSEE_DIR="__ICANSEE_DIR__"

# Read the refs being pushed to figure out the diff range. Git passes them on
# stdin: <local_ref> <local_sha> <remote_ref> <remote_sha> per line.
RANGE=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue  # branch deletion
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch. Diff against the upstream default branch as a heuristic.
    base="$(git merge-base "$local_sha" HEAD@{upstream} 2>/dev/null || echo "")"
    RANGE="${base:-$local_sha~1}..$local_sha"
  else
    RANGE="$remote_sha..$local_sha"
  fi
  break
done

# If we couldn't determine a range, run the audit unconditionally.
RUN=true
if [ -n "$RANGE" ]; then
  CHANGED="$(git diff --name-only "$RANGE" 2>/dev/null || true)"
  if [ -n "$CHANGED" ]; then
    # Skip if every changed file is docs / config that doesn't affect the
    # rendered DOM. Cheap heuristic. False negatives are caught by CI.
    APP_CHANGES="$(echo "$CHANGED" | grep -Ev '^(README|CHANGELOG|LICENSE|\.github/|docs/|\.icansee/)' || true)"
    if [ -z "$APP_CHANGES" ]; then
      echo "icansee: pre-push skipped. No app changes in this push"
      RUN=false
    fi
  fi
fi

if $RUN; then
  "$ICANSEE_DIR/scripts/rendered_audit.sh"
fi
